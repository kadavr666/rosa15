---
/*
  Logo component: SVG lines + HTML text at 20px.
  All coordinates from small house.svg.
  Interactive: ПОЗА → HOME on hover, @ rotates and links to contact.
*/
import { client } from '../lib/sanity';

interface Props {
  debug?: boolean;
  fixed?: boolean;
}
const { debug = false, fixed = true } = Astro.props;

const settings = await client.fetch('*[_type == "siteSettings"][0]{ contactEmail }');
const contactEmail = settings?.contactEmail || '';
---

<div class={`${fixed ? 'fixed-logo' : 'inline-logo'}${debug ? ' logo-debug' : ''}`}>
    <div class="logo-container">
        <img src="/logo_lines.svg" alt="" class="logo-svg" />

        <!-- HOME zone: ПОЗА → HOME on hover -->
        <a href="/" class="home-zone">
            <span class="logo-text home-letter" style="left:22px; top:20px; transform:translate(-50%, -50%);" data-orig="P" data-hover="H">P</span>
            <span class="logo-text home-letter" style="left:62px; top:20px; transform:translate(-50%, -50%);" data-orig="O" data-hover="O">O</span>
            <span class="logo-text home-letter" style="left:22px; top:60px; transform:translate(-50%, -50%);" data-orig="З" data-hover="M">З</span>
            <span class="logo-text home-letter" style="left:62px; top:60px; transform:translate(-50%, -50%);" data-orig="A" data-hover="E">A</span>
        </a>

        <!-- @ contact button -->
        <a href={contactEmail ? `mailto:${contactEmail}` : '#'} class="contact-zone">
            <span class="logo-text contact-at" style="left:20px; top:20px; transform:translate(-50%, -50%);">@</span>
        </a>

        <!-- 15 house number: swings on nail hover -->
        <div class="num-zone">
            <span class="num-anchor">
                <span class="logo-text num-text">15</span>
            </span>
        </div>
    </div>
</div>

<style>
    .fixed-logo {
        position: fixed;
        top: 30px;
        left: 30px;
        z-index: 100;
        mix-blend-mode: exclusion;
    }

    .logo-container {
        position: relative;
        width: 124px;
        height: 164px;
    }

    .logo-svg {
        position: absolute;
        top: 0;
        left: 0;
        width: 124px;
        height: 164px;
        pointer-events: none;
    }

    .logo-text {
        position: absolute;
        font-family: 'Times New Roman', Times, serif;
        font-size: 20px;
        line-height: 1;
        letter-spacing: 0.05em;
        color: #fff;
        text-decoration: none;
        pointer-events: none;
        white-space: nowrap;
        -webkit-font-smoothing: auto;
        -moz-osx-font-smoothing: auto;
    }

    /* HOME zone */
    .home-zone {
        position: absolute;
        left: 0;
        top: 82px;
        width: 82px;
        height: 80px;
        text-decoration: none;
        cursor: pointer;
    }

    .home-zone:hover .home-letter {
        /* JS handles text swap */
    }

    /* @ contact zone */
    .contact-zone {
        position: absolute;
        left: 82px;
        top: 82px;
        width: 40px;
        height: 40px;
        text-decoration: none;
        cursor: pointer;
    }

    .contact-zone:hover .contact-at {
        animation: spin-at 0.6s linear infinite;
    }

    @keyframes spin-at {
        from { transform: translate(-50%, -50%) rotate(0deg); }
        to { transform: translate(-50%, -50%) rotate(360deg); }
    }

    /* 15 house number zone */
    .num-zone {
        position: absolute;
        left: 0;
        top: 42px;
        width: 82px;
        height: 40px;
        cursor: pointer;
    }

    .num-anchor {
        position: absolute;
        left: 42px;
        top: 25px;
        transform: translate(-50%, -50%);
    }

    .num-text {
        position: relative;
        display: block;
        transform-origin: 50% 100%;
    }

    .num-zone:hover .num-text {
        animation: swing-number 1.2s ease-out forwards;
    }

    @keyframes swing-number {
        0%   { transform: rotate(0deg); }
        15%  { transform: rotate(200deg); }
        35%  { transform: rotate(155deg); }
        50%  { transform: rotate(190deg); }
        65%  { transform: rotate(173deg); }
        80%  { transform: rotate(183deg); }
        100% { transform: rotate(180deg); }
    }

    /* Mobile */
    @media (max-width: 768px) {
        .logo-text {
            font-size: 20px;
        }
    }

    /* Debug grid */
    .logo-debug .logo-container {
        background-image:
            linear-gradient(rgba(0, 100, 255, 0.08) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 100, 255, 0.08) 1px, transparent 1px);
        background-size: 5px 5px;
    }

    .logo-debug .logo-text {
        outline: 1px dashed rgba(255, 0, 0, 0.3);
    }
</style>

<script>
    document.querySelectorAll('.home-zone').forEach(zone => {
        const letters = zone.querySelectorAll('.home-letter');
        zone.addEventListener('mouseenter', () => {
            letters.forEach(el => { (el as HTMLElement).textContent = (el as HTMLElement).dataset.hover || ''; });
        });
        zone.addEventListener('mouseleave', () => {
            letters.forEach(el => { (el as HTMLElement).textContent = (el as HTMLElement).dataset.orig || ''; });
        });
    });
</script>
