---
/*
  Logo component: SVG house with text.
  Interactive: РОЗА → HOME on hover, @ rotates and links to contact, 15 swings.
*/
import { client } from '../lib/sanity';

interface Props {
  debug?: boolean;
  fixed?: boolean;
}
const { debug = false, fixed = true } = Astro.props;

const settings = await client.fetch('*[_type == "siteSettings"][0]{ contactEmail }');
const contactEmail = settings?.contactEmail || '';
---

<div class={`${fixed ? 'fixed-logo' : 'inline-logo'}${debug ? ' logo-debug' : ''}`}>
    <div class="logo-container">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="24 234 372 492" class="logo-svg" shape-rendering="crispEdges">
            <!-- House lines -->
            <line x1="30" y1="487.5" x2="30" y2="712.5" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="270" y1="487.5" x2="270" y2="712.5" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="37.5" y1="480" x2="262.5" y2="480" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="37.5" y1="720" x2="262.5" y2="720" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="142.5" y1="367.5" x2="37.5" y2="472.5" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="157.5" y1="367.5" x2="262.5" y2="472.5" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="270" y1="240" x2="157.5" y2="352.5" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="277.5" y1="247.5" x2="382.5" y2="352.5" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="382.5" y1="367.5" x2="277.5" y2="472.5" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="390" y1="367.5" x2="390" y2="592.5" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
            <line x1="382.5" y1="607.5" x2="277.5" y2="712.5" stroke="#fff" stroke-width="1" vector-effect="non-scaling-stroke"/>
        </svg>

        <!-- HOME zone: РОЗА → HOME on hover -->
        <a href="/" class="home-zone">
            <span class="logo-text home-letter" data-orig="Р" data-hover="H">Р</span>
            <span class="logo-text home-letter" data-orig="O" data-hover="O">O</span>
            <span class="logo-text home-letter" data-orig="З" data-hover="M">З</span>
            <span class="logo-text home-letter" data-orig="A" data-hover="E">A</span>
        </a>

        <!-- @ contact button -->
        <a href={contactEmail ? `mailto:${contactEmail}` : '#'} class="contact-zone">
            <span class="logo-text contact-at">@</span>
        </a>

        <!-- 15 house number: swings on hover -->
        <div class="num-zone">
            <span class="logo-text num-text">15</span>
        </div>
    </div>
</div>

<style>
    .fixed-logo {
        position: fixed;
        top: 30px;
        left: 30px;
        z-index: 100;
        mix-blend-mode: exclusion;
    }

    .fixed-logo .logo-container {
        width: 124px;
    }

    .inline-logo .logo-container {
        height: 50vh;
        width: auto;
    }

    .logo-container {
        position: relative;
        aspect-ratio: 372 / 492;
    }

    .logo-svg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

    .logo-text {
        font-family: 'Times New Roman', Times, serif;
        color: #fff;
        text-decoration: none;
        pointer-events: none;
        white-space: nowrap;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    /* HOME zone — main rectangle of the house */
    .home-zone {
        position: absolute;
        left: 1.6%;
        top: 50%;
        width: 64.5%;
        height: 48.8%;
        text-decoration: none;
        cursor: pointer;
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        place-items: center;
    }

    .home-zone .logo-text {
        font-size: 21px;
    }

    .fixed-logo .home-zone .logo-text {
        font-size: 20px;
    }

    /* @ contact zone — right room upper area */
    .contact-zone {
        position: absolute;
        left: 66.1%;
        top: 50%;
        width: 33.9%;
        height: 24.4%;
        text-decoration: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .contact-zone .logo-text {
        font-size: 21px;
    }

    .fixed-logo .contact-zone .logo-text {
        font-size: 20px;
    }

    .contact-zone:hover .contact-at {
        animation: spin-at 0.6s linear infinite;
    }

    @keyframes spin-at {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* 15 house number zone — roof area */
    .num-zone {
        position: absolute;
        left: 1.6%;
        top: 27.2%;
        width: 64.5%;
        height: 24.4%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .num-zone .logo-text {
        font-size: 21px;
        transform-origin: 50% 100%;
    }

    .fixed-logo .num-zone .logo-text {
        font-size: 20px;
    }

    .num-zone:hover .num-text {
        animation: swing-number 1.2s ease-out forwards;
    }

    @keyframes swing-number {
        0%   { transform: rotate(0deg); }
        15%  { transform: rotate(200deg); }
        35%  { transform: rotate(155deg); }
        50%  { transform: rotate(190deg); }
        65%  { transform: rotate(173deg); }
        80%  { transform: rotate(183deg); }
        100% { transform: rotate(180deg); }
    }

    @media (max-width: 1420px) {
        .inline-logo .logo-container {
            height: 50vh;
            width: auto;
        }
    }

    /* Debug grid */
    .logo-debug .logo-container {
        background-image:
            linear-gradient(rgba(0, 100, 255, 0.08) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 100, 255, 0.08) 1px, transparent 1px);
        background-size: 5px 5px;
    }

    .logo-debug .home-zone,
    .logo-debug .contact-zone,
    .logo-debug .num-zone {
        outline: 1px dashed rgba(255, 0, 0, 0.3);
    }
</style>

<script>
    document.querySelectorAll('.home-zone').forEach(zone => {
        const letters = zone.querySelectorAll('.home-letter');
        zone.addEventListener('mouseenter', () => {
            letters.forEach(el => { (el as HTMLElement).textContent = (el as HTMLElement).dataset.hover || ''; });
        });
        zone.addEventListener('mouseleave', () => {
            letters.forEach(el => { (el as HTMLElement).textContent = (el as HTMLElement).dataset.orig || ''; });
        });
    });
</script>
