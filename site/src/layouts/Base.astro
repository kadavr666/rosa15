---
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  noScroll?: boolean;
}
const { title, noScroll = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <main class={noScroll ? 'no-scroll' : ''}>
        <slot />
    </main>
</body>
</html>
