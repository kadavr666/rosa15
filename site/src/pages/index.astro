---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import { client, sanityImageUrl } from '../lib/sanity';

const projects = await client.fetch('*[_type == "project"]{ title, subtitle, slug, heroImage, heroImageHover } | order(_createdAt desc)');
const allSupporters = await client.fetch('array::unique(*[_type == "project"].supporters[].name + *[_type == "supporters"][0].items[].name)');
const supporters = (allSupporters || []).map((name: string) => ({ name }));
---
<Base title="Rosa 15">
    <div class={`projects-grid${projects?.length === 1 ? ' single-project' : ''}`}>
        {projects?.map((p: any, i: number) => {
            const front = p.heroImage ? sanityImageUrl(p.heroImage.asset._ref) : '';
            const back = p.heroImageHover ? sanityImageUrl(p.heroImageHover.asset._ref) : front;
            const slug = p.slug?.current || '';
            const speed = 12 + (i * 7 % 16);
            return (
                <a class="project-card" href={`/project/${slug}`}>
                    <div class="card-flip" style={`animation: card-spin ${speed}s linear infinite`}>
                        {front && <div class="card-face card-front"><img src={front} alt={p.title || ''} /></div>}
                        {back && <div class="card-face card-back"><img src={back} alt={p.title || ''} /></div>}
                    </div>
                    <div class="project-card-title">
                        {p.title || ''}{p.subtitle && <br />}{p.subtitle}
                    </div>
                </a>
            );
        })}
        {supporters.length > 0 && (
            <div class="project-card banner-card">
                <Banner supporters={supporters} />
            </div>
        )}
    </div>
    <Footer />
</Base>

<style>
    .projects-grid {
        display: flex;
        gap: 60px;
        overflow-x: auto;
        padding: 20px;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
    }
    .projects-grid.single-project {
        justify-content: center;
        overflow-x: visible;
    }
    .projects-grid::-webkit-scrollbar { height: 1px; }
    .projects-grid::-webkit-scrollbar-track { background: transparent; }
    .projects-grid::-webkit-scrollbar-thumb { background: #000; }
    .project-card {
        flex: 0 0 auto;
        width: auto;
        height: 100%;
        scroll-snap-align: start;
        text-decoration: none;
        color: #000;
        perspective: 1500px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .card-flip {
        position: relative;
        height: 60vh;
        width: 60vh;
        transform-style: preserve-3d;
    }
    .card-face {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
    }
    .card-face img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }
    .card-back { transform: rotateY(180deg); }
    @keyframes card-spin {
        from { transform: rotateY(0deg); }
        to { transform: rotateY(360deg); }
    }
    .project-card-title {
        font-size: 20px;
        letter-spacing: 0.05em;
        text-align: center;
        padding: 20px 0;
        line-height: 1.5;
        text-decoration: none;
        color: inherit;
    }
    /* Banner card */
    .banner-card {
        perspective: none;
    }
    .banner-card :global(.banner-inner) {
        width: 60vh;
        height: 60vh;
    }

    @media (max-width: 1420px) {
        :global(main) {
            display: block !important;
            height: auto !important;
            overflow: visible !important;
        }
        .projects-grid {
            flex-direction: column;
            flex: none;
            overflow: visible;
            scroll-snap-type: none;
            align-items: center;
            height: auto;
            gap: 80px;
        }
        .project-card { width: 85vw; height: auto; }
        .project-card-title { padding: 20px 0 0; }
        .card-flip { height: 50vh; }
        .banner-card :global(.banner-inner) { width: 85vw; height: 50vh; }
        .banner-card :global(.banner-title) { padding: 20px 0 0; }
    }
</style>

