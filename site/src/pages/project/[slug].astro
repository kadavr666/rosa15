---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import { client, sanityImageUrl } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
    const projects = await client.fetch('*[_type == "project"]{ slug }');
    return projects
        .filter((p: any) => p.slug?.current)
        .map((p: any) => ({ params: { slug: p.slug.current } }));
}

const { slug } = Astro.params;
const project = await client.fetch(
    '*[_type == "project" && slug.current == $slug][0]{ title, subtitle, heroImage, heroImageHover, sections, supporters }',
    { slug }
);


const frontSrc = project?.heroImage ? sanityImageUrl(project.heroImage.asset._ref) : '/hero.jpg';
const backSrc = project?.heroImageHover ? sanityImageUrl(project.heroImageHover.asset._ref) : '/hero2.jpg';
const title = project?.title || 'Project';
---
<Base title={`${title} - Rosa 15`}>
    <div class="hero-container">
        <div class="hero-card">
            <div class="hero-face hero-front"><img src={frontSrc} alt={title} /></div>
            <div class="hero-face hero-back"><img src={backSrc} alt={title} /></div>
        </div>
    </div>

    <div id="sections">
        {project?.sections?.map((section: any) => {
            if (section._type === 'textSection') {
                return (
                    <div class="text-section">
                        {(section.title || section.subtitle) && (
                            <div class="title">
                                {section.subtitle && <>{section.subtitle}<br /></>}
                                {section.title}
                            </div>
                        )}
                        {section.body && (
                            Array.isArray(section.body)
                                ? <Fragment set:html={toHTML(section.body, {
                                    components: {
                                        marks: {
                                            link: ({ children, value }: any) =>
                                                `<a href="${value.href}"${value.blank ? ' target="_blank" rel="noopener"' : ''}>${children}</a>`,
                                        },
                                    },
                                })} />
                                : <p>{section.body}</p>
                        )}
                    </div>
                );
            }
            if (section._type === 'listSection') {
                return (
                    <section class="crowdfunding">
                        {section.title && <div class="title">{section.title}</div>}
                        {section.description && <p>{section.description}</p>}
                        {section.items?.map((item: any) => (
                            <div class="list-item" data-price={item.price || ''}>
                                <div class="item-title">{item.title || ''}</div>
                                <div class="item-desc">{item.description || ''}</div>
                            </div>
                        ))}
                    </section>
                );
            }
        })}
    </div>

    {project?.supporters?.length > 0 && (
        <div class="project-supporters">
            <div class="title">PEOPLE SUPPORTED ({project.supporters.length})</div>
            {project.supporters.map((s: any) => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="58 -2 184 285" width="184" height="285" shape-rendering="crispEdges">
                    <circle cx="150" cy="40" r="40" fill="none" stroke="currentColor" stroke-width="1.3"/>
                    <line x1="150" y1="90" x2="150" y2="170" stroke="currentColor" stroke-width="1.3"/>
                    <line x1="145" y1="175" x2="90" y2="240" stroke="currentColor" stroke-width="1.3"/>
                    <line x1="155" y1="175" x2="210" y2="240" stroke="currentColor" stroke-width="1.3"/>
                    <line x1="145" y1="85" x2="60" y2="155" stroke="currentColor" stroke-width="1.3"/>
                    <line x1="155" y1="85" x2="240" y2="155" stroke="currentColor" stroke-width="1.3"/>
                    <text x="150" y="255" font-family="'Times New Roman', serif" font-size="16" letter-spacing="0.8" fill="currentColor" text-anchor="middle" dominant-baseline="central">{s.name}</text>
                </svg>
            ))}
        </div>
    )}

    <Footer />
</Base>

<script>
(function () {
    const card = document.querySelector('.hero-card') as HTMLElement | null;
    if (!card) return;
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

    const DURATION = 16;
    const FRICTION = 0.95;
    const VELOCITY_THRESHOLD = 0.05;
    const AUTO_RESUME_DELAY = 10000;

    let isDragging = false;
    let dragStartX = 0;
    let angleAtDragStart = 0;
    let currentAngle = 0;
    let velocity = 0;
    let lastX = 0;
    let momentumRAF: number | null = null;
    let autoResumeTimeout: ReturnType<typeof setTimeout> | null = null;

    function getAngleFromMatrix(): number {
        const t = window.getComputedStyle(card!).transform;
        if (!t || t === 'none') return 0;
        const m = new DOMMatrix(t);
        return Math.atan2(m.m31, m.m11) * (180 / Math.PI);
    }

    function resumeFrom(angle: number) {
        const normalized = ((angle % 360) + 360) % 360;
        const delay = -((normalized / 360) * DURATION);
        card!.style.animation = 'none';
        card!.offsetHeight;
        card!.style.transform = '';
        card!.style.animation = `hero-spin ${DURATION}s ${delay}s linear infinite`;
    }

    function cancelPending() {
        if (momentumRAF !== null) { cancelAnimationFrame(momentumRAF); momentumRAF = null; }
        if (autoResumeTimeout !== null) { clearTimeout(autoResumeTimeout); autoResumeTimeout = null; }
    }

    card.addEventListener('mousedown', (e: MouseEvent) => {
        cancelPending();
        isDragging = true;
        dragStartX = e.clientX;
        lastX = e.clientX;
        velocity = 0;
        angleAtDragStart = getAngleFromMatrix();
        currentAngle = angleAtDragStart;
        card!.style.animation = 'none';
        card!.style.transform = `rotateY(${angleAtDragStart}deg)`;
        document.body.classList.add('is-dragging');
        document.documentElement.style.userSelect = 'none';
        e.preventDefault();
    });

    window.addEventListener('mousemove', (e: MouseEvent) => {
        if (!isDragging) return;
        velocity = e.clientX - lastX;
        lastX = e.clientX;
        currentAngle = angleAtDragStart + (e.clientX - dragStartX) * 0.5;
        card!.style.transform = `rotateY(${currentAngle}deg)`;
    });

    window.addEventListener('mouseup', () => {
        if (!isDragging) return;
        isDragging = false;
        document.body.classList.remove('is-dragging');
        document.documentElement.style.userSelect = '';

        let vel = velocity * 0.8;

        function momentumStep() {
            vel *= FRICTION;
            currentAngle += vel;
            card!.style.transform = `rotateY(${currentAngle}deg)`;
            if (Math.abs(vel) > VELOCITY_THRESHOLD) {
                momentumRAF = requestAnimationFrame(momentumStep);
            } else {
                momentumRAF = null;
                autoResumeTimeout = setTimeout(() => resumeFrom(currentAngle), AUTO_RESUME_DELAY);
            }
        }

        momentumRAF = requestAnimationFrame(momentumStep);
    });
})();
</script>
