---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';

const tracks = [
    { id: 1, title: 'Annushka', file: '/audio/track01.mp3' },
    { id: 2, title: 'Suna no Onna', file: '/audio/track02.mp3' },
    { id: 3, title: 'Antuni', file: '/audio/track03.mp3' },
    { id: 4, title: 'Ani', file: '/audio/track04.mp3' },
    { id: 5, title: 'Tsitsernak', file: '/audio/track05.mp3' },
    { id: 6, title: 'Businy-Glazki', file: '/audio/track06.mp3' },
    { id: 7, title: 'Spitak', file: '/audio/track07.mp3' },
    { id: 8, title: 'Seance', file: '/audio/track08.mp3' },
];
---
<Base title="Rosa 15">
    <div class="player-page">
        <div class="player-wrap">
            <div class="info-col">
                <div class="info-table">
                    <div class="info-row"><span class="info-label">Artist</span><span class="info-value">Margenrot</span></div>
                    <div class="info-row"><span class="info-label">Title</span><span class="info-value">Antuni</span></div>
                    <div class="info-row"><span class="info-label">Label</span><span class="info-value">Rosa15</span></div>
                    <div class="info-row"><span class="info-label">Format</span><span class="info-value">LP, Digital</span></div>
                    <div class="info-row"><span class="info-label">Release date</span><span class="info-value">July 15 2026</span></div>
                    <div class="info-row"><span class="info-label">Catalogue No.</span><span class="info-value">CAT#1</span></div>
                </div>
                <p class="info-desc">"Antuni" is the third album by an Armenian musician from Siberia, Lusia Kazaryan (MARGENROT). In her work, Lusia addresses the issue of national identity and reinterprets traditional Armenian chants and chorales, weaving them into experimental electronic music as well as incorporating the sounds of her surrounding environment. Antuni is a genre of gusan song (gusans were Armenian folk singers and rhapsodes) – a story told by a homeless, eternal wanderer, exiled and deprived of homeland. The album's title also refers to the melancholic ballad Antuni ("The Song of the Wanderer") by the Armenian composer, folklorist, and monk Komitas. This work was dedicated to the victims of the Armenian Genocide of 1915. Lusia's new album is a reflection of her own existential experience: a wandering of the lonely soul amid numerous contemporary wars. She asks an urgent, personal question: "What is my home, and where is it?"</p>
            </div>
            <div class="player-col">
                <img src="/hero.jpg" alt="Antuni" class="artwork" />
                <div class="controls">
                    <div class="progress-wrap">
                        <span id="current-time">0:00</span>
                        <div class="progress-bar" id="progress-bar">
                            <div class="progress-fill" id="progress-fill"></div>
                            <div class="progress-handle" id="progress-handle"></div>
                        </div>
                        <span id="total-time">0:00</span>
                    </div>
                </div>
                <div class="tracklist">
                    {tracks.map((t) => (
                        <div class="track-item" data-src={t.file} data-index={t.id - 1}>
                            <span class="track-num">{t.id}</span>
                            <span class="track-title">{t.title}</span>
                            <span class="track-duration"></span>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
    <div class="mobile-footer">
        <Footer />
    </div>
</Base>

<script>
    const tracks = [
        { title: 'Annushka', file: '/audio/track01.mp3' },
        { title: 'Suna no Onna', file: '/audio/track02.mp3' },
        { title: 'Antuni', file: '/audio/track03.mp3' },
        { title: 'Ani', file: '/audio/track04.mp3' },
        { title: 'Tsitsernak', file: '/audio/track05.mp3' },
        { title: 'Businy-Glazki', file: '/audio/track06.mp3' },
        { title: 'Spitak', file: '/audio/track07.mp3' },
        { title: 'Seance', file: '/audio/track08.mp3' },
    ];

    const audio = new Audio();
    let current = -1;

    const progressFill = document.getElementById('progress-fill') as HTMLElement;
    const progressBar = document.getElementById('progress-bar') as HTMLElement;
    const progressHandle = document.getElementById('progress-handle') as HTMLElement;
    const currentTimeEl = document.getElementById('current-time') as HTMLElement;
    const totalTimeEl = document.getElementById('total-time') as HTMLElement;
    const trackItems = document.querySelectorAll('.track-item');

    function fmt(s: number) {
        const m = Math.floor(s / 60);
        const sec = Math.floor(s % 60);
        return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function updateNums() {
        trackItems.forEach((el, i) => {
            el.classList.toggle('active', i === current);
        });
    }

    function load(idx: number) {
        current = idx;
        audio.src = tracks[idx].file;
        audio.play();
        totalTimeEl.textContent = '0:00';
        updateNums();
    }

    trackItems.forEach((el, i) => {
        el.addEventListener('click', () => {
            if (current === i) {
                if (audio.paused) { audio.play(); } else { audio.pause(); }
                updateNums();
            } else {
                load(i);
            }
        });

    });

    function updateProgress(pct: number) {
        progressFill.style.width = pct + '%';
        progressHandle.style.left = pct + '%';
    }

    audio.addEventListener('timeupdate', () => {
        if (!audio.duration) return;
        const pct = (audio.currentTime / audio.duration) * 100;
        updateProgress(pct);
        currentTimeEl.textContent = fmt(audio.currentTime);
    });

    audio.addEventListener('loadedmetadata', () => {
        totalTimeEl.textContent = fmt(audio.duration);
        // update duration display on the active track item
        if (current >= 0) {
            const dur = (trackItems[current] as HTMLElement).querySelector('.track-duration') as HTMLElement;
            if (dur) dur.textContent = fmt(audio.duration);
        }
    });

    audio.addEventListener('ended', () => {
        if (current < tracks.length - 1) {
            load(current + 1);
        } else {
            current = -1;
            updateNums();
        }
    });

    function seek(clientX: number) {
        const rect = progressBar.getBoundingClientRect();
        const pct = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
        audio.currentTime = pct * audio.duration;
        updateProgress(pct * 100);
    }

    progressBar.addEventListener('click', (e: MouseEvent) => seek(e.clientX));

    let dragging = false;
    progressHandle.addEventListener('mousedown', (e: MouseEvent) => {
        dragging = true;
        e.preventDefault();
    });
    document.addEventListener('mousemove', (e: MouseEvent) => {
        if (!dragging) return;
        seek(e.clientX);
    });
    document.addEventListener('mouseup', () => { dragging = false; });

    // touch
    progressHandle.addEventListener('touchstart', (e: TouchEvent) => { dragging = true; e.preventDefault(); }, { passive: false });
    document.addEventListener('touchmove', (e: TouchEvent) => {
        if (!dragging) return;
        seek(e.touches[0].clientX);
    });
    document.addEventListener('touchend', () => { dragging = false; });

    // preload durations for all tracks
    tracks.forEach((t, i) => {
        const tmp = new Audio();
        tmp.preload = 'metadata';
        tmp.src = t.file;
        tmp.addEventListener('loadedmetadata', () => {
            const dur = (trackItems[i] as HTMLElement).querySelector('.track-duration') as HTMLElement;
            if (dur) dur.textContent = fmt(tmp.duration);
        });
    });
</script>

<style>
    .player-page {
        min-height: 100vh;
        display: flex;
        align-items: stretch;
        justify-content: center;
        padding: 0 30px;
    }

    .artwork {
        width: auto;
        height: 30vh;
        display: block;
        margin: 0 auto 40px;
    }

    .player-wrap {
        width: 100%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        align-items: start;
    }

    .mobile-footer {
        display: none;
        margin-top: 60px;
    }

    /* ── Info column ── */

    .info-col {
        padding: 40px 30px 40px 0;
        min-height: 100vh;
        position: relative;
    }

    .info-col::after {
        content: '';
        position: absolute;
        top: 20px;
        bottom: 20px;
        right: 0;
        width: 1px;
        background: #000;
    }

    .player-col {
        padding: 40px 0 40px 30px;
    }

    .info-table {
        display: flex;
        flex-direction: column;
    }

    .info-row {
        display: flex;
        gap: 20px;
        padding: 6px 0;
        border-bottom: 1px solid #000;
        font-size: 22px;
        letter-spacing: 0.05em;
        line-height: 1.3;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        flex: 0 0 160px;
        opacity: 1;
    }

    .info-value {
        flex: 1;
    }

    .disclaimer {
        font-size: 22px;
        letter-spacing: 0.05em;
        line-height: 1.3;
        margin-top: 40px;
        color: #999;
    }

    .info-desc {
        font-size: 22px;
        letter-spacing: 0.05em;
        line-height: 1.3;
        margin-top: 80px;
    }

    /* ── Player column ── */

    .controls {
        margin-bottom: 40px;
    }

    .track-item {
        display: flex;
        align-items: baseline;
        gap: 20px;
        padding: 6px 0;
        border-bottom: 1px solid #000;
        cursor: pointer;
        font-size: 22px;
        letter-spacing: 0.05em;
        line-height: 1.3;
    }

    .track-item:first-child {
        border-top: none;
    }

    .track-item:last-child {
        border-bottom: none;
    }

    .track-item.active {
        font-style: italic;
    }

    .track-num {
        flex: 0 0 24px;
        font-size: 22px;
    }

    .track-title {
        flex: 1;
    }

    .track-duration {
        flex: 0 0 auto;
        opacity: 1;
        font-size: 22px;
        letter-spacing: 0.05em;
    }

    .progress-wrap {
        display: flex;
        align-items: center;
        gap: 20px;
        font-size: 22px;
        letter-spacing: 0.05em;
    }

    .progress-bar {
        flex: 1;
        height: 1px;
        background: #000;
        cursor: pointer;
        position: relative;
    }

    .progress-fill {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: #000;
        width: 0%;
        transition: width 0.1s linear;
    }

    .progress-handle {
        position: absolute;
        top: 50%;
        left: 0%;
        transform: translate(-50%, -50%);
        width: 18px;
        height: 18px;
        background: #fff;
        border: 1px solid #000;
        border-radius: 50%;
        cursor: grab;
        transition: left 0.1s linear;
    }

    .progress-handle:active {
        cursor: grabbing;
    }

    @media (max-width: 1100px) {
        .player-page {
            padding: 0 20px;
        }

        .player-wrap {
            grid-template-columns: 1fr;
        }

        .info-col {
            padding: 40px 0 40px 0;
            border-right: none;
            min-height: 0;
            order: 2;
        }

        .info-col::after {
            display: none;
        }

        .player-col {
            padding: 20px 0 40px 0;
            order: 1;
        }

        .info-label {
            flex: 0 0 130px;
        }

        :global(.fixed-logo) {
            display: none;
        }

        .mobile-footer {
            display: block;
        }
    }

    @media (max-width: 768px) {
        .artwork {
            width: 100%;
            height: auto;
        }

        .track-item,
        .track-num,
        .track-duration,
        .progress-wrap,
        .info-row,
        .info-desc,
        .disclaimer {
            font-size: 20px;
        }
    }
</style>
