---
import { client, sanityImageUrl } from '../../../lib/sanity';

export async function getStaticPaths() {
    const projects = await client.fetch('*[_type == "project"]{ slug }');
    return projects
        .filter((p: any) => p.slug?.current)
        .map((p: any) => ({ params: { slug: p.slug.current } }));
}

const { slug } = Astro.params;
const project = await client.fetch(
    '*[_type == "project" && slug.current == $slug][0]{ title, supporters }',
    { slug }
);

const supporters = project?.supporters || [];
// Duplicate for seamless loop
const doubled = [...supporters, ...supporters];
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{project?.title} — Supporters</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #fff;
            height: 100vh;
            display: flex;
            align-items: center;
            overflow: hidden;
        }

        .track {
            display: flex;
            align-items: flex-end;
            animation: scroll linear infinite;
            animation-duration: calc(var(--count) * 3s);
            will-change: transform;
        }

        .track svg {
            flex-shrink: 0;
        }

        @keyframes scroll {
            from { transform: translateX(0); }
            to   { transform: translateX(calc(-50%)); }
        }
    </style>
</head>
<body>
    <div class="track" style={`--count: ${supporters.length}`}>
        {doubled.map((s: any) => (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="90 51.5 120 237" width="120" height="237">
                <circle cx="147.5" cy="82.5" r="29" fill="none" stroke="#000" stroke-width="1"/>
                <line x1="147.5" y1="122.5" x2="147.5" y2="187.5" stroke="#000" stroke-width="1"/>
                <line x1="145" y1="190" x2="97.5" y2="240" stroke="#000" stroke-width="1"/>
                <line x1="150" y1="190" x2="197.5" y2="240" stroke="#000" stroke-width="1"/>
                <line x1="145" y1="117.5" x2="87.5" y2="170" stroke="#000" stroke-width="1"/>
                <line x1="150" y1="117.5" x2="207.5" y2="167.5" stroke="#000" stroke-width="1"/>
                <foreignObject x="95" y="242" width="110" height="46">
                    <div style="font-family:'Times New Roman',serif; font-size:16px; letter-spacing:0.8px; text-align:center; line-height:1.4; overflow-wrap:break-word;">{s.name}</div>
                </foreignObject>
            </svg>
        ))}
    </div>
</body>
</html>
